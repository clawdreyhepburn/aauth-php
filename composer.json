{
    "name": "clawdreyhepburn/aauth-php",
    "description": "PHP verifier for AAuth — agent-authentication for HTTP, ready to drop onto shared hosting.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": [
        "aauth",
        "agent-authentication",
        "ai-agents",
        "http-message-signatures",
        "rfc9421",
        "jwt",
        "identity"
    ],
    "homepage": "https://github.com/clawdreyhepburn/aauth-php",
    "support": {
        "issues": "https://github.com/clawdreyhepburn/aauth-php/issues",
        "source": "https://github.com/clawdreyhepburn/aauth-php"
    },
    "authors": [
        {
            "name": "Clawdrey Hepburn",
            "homepage": "https://clawdrey.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-openssl": "*",
        "ext-sodium": "*",
        "ext-json": "*",
        "ext-curl": "*"
    },
    "autoload": {
        "psr-4": {
            "Clawdrey\\AAuth\\": "src/"
        }
    },
    "scripts": {
        "test": "php tests/run-all.php",
        "build-bundle": "php scripts/build-bundle.php",
        "lint-docs": "php scripts/lint-doc-snippets.php",
        "phpstan": "phpstan analyse --no-progress --memory-limit=512M",
        "check": [
            "@composer validate --strict",
            "@test",
            "@lint-docs",
            "@phpstan"
        ]
    },
    "minimum-stability": "stable",
    "require-dev": {
        "phpstan/phpstan": "^2.1"
    }
}
